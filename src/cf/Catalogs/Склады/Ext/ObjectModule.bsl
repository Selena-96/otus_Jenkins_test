
Процедура ПередЗаписью(Отказ)
	
	Запрос = Новый Запрос("ВЫБРАТЬ Истина КАК Проверка");
	Рез = Запрос.Выполнить().Выбрать();
	Пока Рез.Следующий() Цикл
		Если Ложь Тогда
			Прервать;
		КонецЕсли;
				
		Если НЕ Рез.Проверка Тогда
			НеИспользовать = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
		
КонецПроцедуры
